{
  "version": "1.0",
  "description": "OpsFlow 可用原子操作索引 — 供 LLM 读取",
  "atoms": [
    {
      "name": "disk_check",
      "description": "检查远程主机磁盘使用率",
      "risk_level": "low",
      "group": "check",
      "inputs": ["warning_threshold", "mount_point"],
      "outputs": ["usage_percent", "total_gb", "used_gb", "avail_gb"]
    },
    {
      "name": "ping_test",
      "description": "测试目标主机网络连通性",
      "risk_level": "low",
      "group": "check",
      "inputs": ["target_host", "count"],
      "outputs": ["packet_loss", "latency_ms"]
    },
    {
      "name": "health_check",
      "description": "对服务端点进行 HTTP 健康检查",
      "risk_level": "low",
      "group": "check",
      "inputs": ["url", "expected_status", "timeout"],
      "outputs": ["status", "response_time_ms", "body"]
    },
    {
      "name": "shell",
      "description": "在远程主机上执行 Shell 命令",
      "risk_level": "medium",
      "group": "action",
      "inputs": ["command", "working_dir"],
      "outputs": ["stdout", "stderr", "returncode"]
    },
    {
      "name": "script_exec",
      "description": "上传并执行远程脚本文件",
      "risk_level": "medium",
      "group": "action",
      "inputs": ["script_content", "script_type", "args"],
      "outputs": ["stdout", "stderr", "returncode"]
    },
    {
      "name": "file_copy",
      "description": "复制文件到远程主机指定路径",
      "risk_level": "medium",
      "group": "action",
      "inputs": ["src", "dest", "owner", "mode"],
      "outputs": ["changed", "dest_path"]
    },
    {
      "name": "upload_file",
      "description": "上传本地文件到远程主机",
      "risk_level": "medium",
      "group": "action",
      "inputs": ["src", "dest", "owner", "mode"],
      "outputs": ["changed", "dest_path"]
    },
    {
      "name": "backup_file",
      "description": "备份远程主机上的文件或目录",
      "risk_level": "low",
      "group": "action",
      "inputs": ["src", "backup_dir"],
      "outputs": ["backup_path", "size_bytes"]
    },
    {
      "name": "nginx_reload",
      "description": "验证并重载 Nginx 配置",
      "risk_level": "medium",
      "group": "action",
      "inputs": ["config_path", "test_config"],
      "outputs": ["config_valid", "reload_success"]
    },
    {
      "name": "docker_deploy",
      "description": "部署 Docker 容器",
      "risk_level": "high",
      "group": "action",
      "inputs": ["image", "container_name", "ports", "env_vars", "volumes"],
      "outputs": ["container_id", "deploy_success"]
    },
    {
      "name": "java_deploy",
      "description": "部署 Java 应用（上传 JAR/WAR + 重启服务）",
      "risk_level": "high",
      "group": "action",
      "inputs": ["artifact_path", "target_path", "service_name", "jvm_args"],
      "outputs": ["deploy_success", "service_status"]
    },
    {
      "name": "service_control",
      "description": "控制系统服务的启动/停止/重启/重载",
      "risk_level": "high",
      "group": "control",
      "inputs": ["service", "action", "enabled"],
      "outputs": ["changed", "status"]
    },
    {
      "name": "send_alert",
      "description": "发送告警通知（短信/邮件/企微）",
      "risk_level": "low",
      "group": "control",
      "inputs": ["channel", "title", "message", "recipients"],
      "outputs": ["sent", "message_id"]
    }
  ]
}
