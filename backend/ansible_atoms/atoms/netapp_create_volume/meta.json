{
  "name": "netapp_create_volume",
  "description": "在 NetApp ONTAP 上创建 FlexVol 存储卷",
  "risk_level": "high",
  "group": "storage",
  "component_code": "opsflow_netapp_create_volume",
  "executor_type": "netapp",
  "inputs": [
    {"name": "cluster_ip", "type": "string", "required": true, "description": "ONTAP 集群管理 IP"},
    {"name": "svm_name", "type": "string", "required": true, "description": "SVM (Storage VM) 名称"},
    {"name": "volume_name", "type": "string", "required": true, "description": "卷名称"},
    {"name": "size_gb", "type": "int", "required": true, "description": "卷大小 (GB)"},
    {"name": "aggregate", "type": "string", "required": true, "description": "所属 Aggregate"},
    {"name": "snapshot_policy", "type": "string", "default": "", "description": "快照策略 (可选)"}
  ],
  "outputs": [
    {"name": "volume_uuid", "type": "string", "description": "卷 UUID"},
    {"name": "volume_name", "type": "string"},
    {"name": "mount_path", "type": "string", "description": "挂载路径"}
  ],
  "rollback": "netapp_delete_volume",
  "dependencies": []
}
