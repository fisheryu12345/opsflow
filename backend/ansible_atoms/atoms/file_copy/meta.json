{
  "name": "file_copy",
  "description": "复制文件或目录到远程主机",
  "risk_level": "medium",
  "group": "action",
  "component_code": "opsflow_file_copy",
  "inputs": [
    {
      "name": "src",
      "type": "string",
      "default": "",
      "description": "源路径"
    },
    {
      "name": "dest",
      "type": "string",
      "default": "",
      "description": "目标路径"
    },
    {
      "name": "owner",
      "type": "string",
      "default": "",
      "description": "文件所有者"
    },
    {
      "name": "mode",
      "type": "string",
      "default": "0644",
      "description": "文件权限"
    }
  ],
  "outputs": [
    {
      "name": "changed",
      "type": "bool",
      "description": "是否发生变更"
    },
    {
      "name": "dest_path",
      "type": "string",
      "description": "实际写入路径"
    }
  ],
  "rollback": "delete_file",
  "dependencies": [],
  "executor_type": "ansible"
}
