{
  "name": "esxi_create_vm",
  "description": "在 ESXi/vCenter 上创建虚拟机",
  "risk_level": "high",
  "group": "vmware",
  "component_code": "opsflow_esxi_create_vm",
  "executor_type": "esxi",
  "inputs": [
    {"name": "esxi_host", "type": "string", "required": true, "description": "ESXi 主机 IP 或 vCenter FQDN"},
    {"name": "vm_name", "type": "string", "required": true, "description": "虚拟机名称"},
    {"name": "cpu", "type": "int", "default": 2, "description": "CPU 核数"},
    {"name": "memory_mb", "type": "int", "default": 4096, "description": "内存大小 (MB)"},
    {"name": "disk_gb", "type": "int", "default": 50, "description": "系统盘大小 (GB)"},
    {"name": "datastore", "type": "string", "required": true, "description": "数据存储名称"},
    {"name": "network", "type": "string", "default": "VM Network", "description": "网络名称"}
  ],
  "outputs": [
    {"name": "vm_id", "type": "string", "description": "VM 实例 MoID"},
    {"name": "vm_name", "type": "string", "description": "VM 名称"},
    {"name": "power_state", "type": "string", "description": "电源状态"}
  ],
  "rollback": "esxi_destroy_vm",
  "dependencies": []
}
