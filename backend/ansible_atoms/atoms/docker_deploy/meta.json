{
  "name": "docker_deploy",
  "description": "部署 Docker 容器：拉取镜像、创建并启动容器",
  "risk_level": "high",
  "group": "action",
  "component_code": "opsflow_docker_deploy",
  "inputs": [
    {"name": "image", "type": "string", "default": "", "description": "Docker 镜像名称:tag"},
    {"name": "container_name", "type": "string", "default": "", "description": "容器名称"},
    {"name": "ports", "type": "dict", "default": {}, "description": "端口映射: {host_port: container_port}"},
    {"name": "env_vars", "type": "dict", "default": {}, "description": "环境变量: {key: value}"},
    {"name": "volumes", "type": "dict", "default": {}, "description": "卷映射: {host_path: container_path}"}
  ],
  "outputs": [
    {"name": "container_id", "type": "string", "description": "创建的容器 ID"},
    {"name": "deploy_success", "type": "bool", "description": "部署是否成功"}
  ],
  "rollback": "docker_rm",
  "dependencies": []
}
