{
  "name": "nginx_reload",
  "description": "验证 Nginx 配置并执行重载",
  "risk_level": "medium",
  "group": "action",
  "component_code": "opsflow_nginx_reload",
  "inputs": [
    {"name": "config_path", "type": "string", "default": "/etc/nginx/nginx.conf", "description": "Nginx 配置文件路径"},
    {"name": "test_config", "type": "bool", "default": true, "description": "重载前是否执行配置测试"}
  ],
  "outputs": [
    {"name": "config_valid", "type": "bool", "description": "配置文件是否有效"},
    {"name": "reload_success", "type": "bool", "description": "重载是否成功"}
  ],
  "rollback": "service_control",
  "dependencies": []
}
