[server]
host = "0.0.0.0"
port = 18080

[ws]
host = "0.0.0.0"
port = 8081
path = "/ws"
max_conn = 10000
heartbeat_check = 90
default_interval = 30

[store]
data_dir = "/var/lib/opsflow-agent/server"
boltdb_path = "/var/lib/opsflow-agent/server/db/agent-server.db"

[django]
base_url = "http://localhost:8000"
api_token = ""
batch_size = 50
batch_every = 2

[log]
level = "info"
file = "/var/log/opsflow-agent/server.log"
max_size = 100
max_backups = 7
